{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "src/api/**/*",
    "src/ui/**/*",
    "src/config.ts",
    "src/fixtures.ts",
    "tests/**/*",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
